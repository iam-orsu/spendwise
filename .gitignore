# Node.js dependencies
# This folder is auto-generated by npm install from package.json.
# Never commit it. Anyone cloning the repo runs npm install to recreate it.
node_modules/

# SQLite database files
# The application creates this automatically on first run.
# It contains live data and must never be version-controlled.
*.db

# Environment variable files
# These contain secrets: JWT keys, database passwords, API keys.
# We will introduce proper .env handling in File 04.
.env
.env.local
.env.*.local

# Operating system files
# macOS creates .DS_Store in every folder. Windows creates Thumbs.db.
# These are local system files with no relevance to the project.
.DS_Store
Thumbs.db

# Code editor configuration
# These are personal settings that vary per developer.
.vscode/
.idea/
*.suo
*.user